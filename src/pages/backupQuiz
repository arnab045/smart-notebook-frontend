            {currentPage > 1 && <button onClick={() => setCurrentPage(p => p - 1)} className="flex items-center bg-stone-100 hover:bg-stone-200 text-stone-700 text-xs py-2 px-3.5 rounded border border-stone-300 cursor-pointer transition-all"><ArrowLeft className="w-4.5 h-4.5 mr-1" />Previous Page</button>}
            {currentPage < totalPages ? <button onClick={() => setCurrentPage(p => p + 1)} className="flex items-center bg-stone-800 hover:bg-stone-900 text-white text-xs py-2 px-3.5 rounded cursor-pointer transition-all">Next Page<ArrowRight className="w-4.5 h-4.5 ml-1" /></button> :
              <button onClick={onSubmit} className={`relative overflow-hidden flex items-center text-xs py-2.5 px-5 rounded font-bold cursor-pointer transition-all ${isAllAnswered ? 'bg-gradient-to-r from-red-800 to-red-700 text-orange-50 shadow hover:from-red-900 hover:to-red-800 border border-red-950' : 'bg-stone-200 border border-stone-300 text-stone-500 cursor-not-allowed'}`} title={isAllAnswered ? "Submit entire exam sheet" : `Answer all ${questions.length} questions before submitting`}>
                <PenTool className="w-4 h-4 mr-1.5" />Submit Exam Paper{!isAllAnswered && <span className="absolute bottom-0.5 right-1.5 text-[8px] opacity-75 font-mono">({answeredCount}/{questions.length})</span>}
              </button>
            }
          </div>
        </div>
      </div>
    </div>
  );
};


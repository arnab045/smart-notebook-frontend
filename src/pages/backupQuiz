          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 border border-stone-300 rounded p-4 bg-stone-50/50 mt-6 text-xs max-w-xl"><div><span className="text-stone-500 font-mono text-[9px] block mb-1">CANDIDATE:</span><span className="font-handwritten text-lg text-blue-900 font-bold">{candidateName}</span></div><div><span className="text-stone-500 font-mono text-[9px] block mb-1">SCORE METRIC:</span><span className="font-serif text-sm text-stone-800 font-bold">{correctCount} / {totalPossible} Correct Answers ({percentage}%)</span></div></div>

const Quiz = () => {
  const [gameState, setGameState] = useState('CONFIG');
  const [config, setConfig] = useState(null);
  const [sampledQuestions, setSampledQuestions] = useState([]);
  const [selectedAnswers, setSelectedAnswers] = useState({});

  const handleStartExam = (newConfig) => {
    setConfig(newConfig);
    const matchingPool = QUESTIONS_DB.filter(q => newConfig.selectedTopics.some(topic => q.topic.toLowerCase().includes(topic.toLowerCase()) || topic.toLowerCase().includes(q.topic.toLowerCase())));
    const finalPool = matchingPool.length > 0 ? matchingPool : QUESTIONS_DB;
    const shuffled = [...finalPool].sort(() => 0.5 - Math.random());
    const selectedQuestionsSet = shuffled.slice(0, Math.min(newConfig.numQuestions, shuffled.length)).sort((a, b) => a.id - b.id);
    setSampledQuestions(selectedQuestionsSet);
    setSelectedAnswers({});
    setGameState('QUIZ');
  };

  const handleSelectAnswer = (questionId, answer) => setSelectedAnswers(prev => ({ ...prev, [questionId]: answer }));
  const handleSubmitExam = () => setGameState('RESULTS');
  const handleRestart = () => { setConfig(null); setSampledQuestions([]); setSelectedAnswers({}); setGameState('CONFIG'); };

  return (
    <MainLayout>
    <div className="wood-desk-bg min-h-screen py-8 px-4 sm:px-6 md:px-8 flex flex-col items-center justify-start text-stone-900 relative overflow-x-hidden font-sans">

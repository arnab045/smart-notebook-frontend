                <div className="grid grid-cols-1 gap-2.5 mt-2 max-w-3xl">
                  {['A', 'B', 'C', 'D'].map(optKey => {
                    const isSelected = selectedAnswer === optKey;
                    return (
                      <button key={optKey} onClick={() => onSelectAnswer(q.id, optKey)} className={`group relative text-left border rounded-lg p-3 sm:px-4 sm:py-3.5 hover:bg-neutral-50/80 transition-all font-serif flex items-start gap-3.5 cursor-pointer ${isSelected ? 'bg-amber-50/20 border-amber-800 ring-1 ring-amber-700' : 'bg-white border-neutral-200 text-stone-700'}`}>
                        <div className={`w-5 h-5 rounded-full border flex items-center justify-center font-mono font-bold text-xs shrink-0 select-none mt-0.5 transition-all ${isSelected ? 'bg-amber-800 text-white border-amber-900' : 'bg-white border-stone-300 text-stone-500 group-hover:bg-neutral-100'}`}>{optKey}</div>
                        <span className="text-xs sm:text-sm leading-relaxed text-stone-800 pt-0.5 pr-8">{q.options[optKey]}</span>

        <AnimatePresence mode="wait">
          <motion.div
            key={gameState}
            initial={{ opacity: 0, y: 15 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -15 }}
            transition={{ duration: 0.35, ease: 'easeInOut' }}
            className="w-full relative"
          >

            <h1 className="text-white text-4xl">
              TEST
            </h1>

          </motion.div>
        </AnimatePresence>
        {gameState !== 'QUIZ' && <div className="mt-4 pointer-events-auto"><div className="bg-amber-100 border-l-4 border-amber-400 shadow-[0_4px_10px_2px_rgba(0,0,0,0.15)] p-4 max-w-sm rounded-r-md mx-auto my-6 relative transform rotate-1"><div className="absolute top-[-10px] left-[50%] -translate-x-1/2 w-3 h-3 bg-red-500 rounded-full shadow" /><div className="pl-6 select-none"><h4 className="font-handwritten text-lg font-bold text-amber-900 leading-tight">📝 CANDIDATE CODE OF INTERNALS:</h4><ul className="list-disc pl-4 mt-2 space-y-1 font-handwritten text-[14px] text-amber-800"><li>No textbooks, calculators or cheat-sheets are permitted.</li><li>Write all answers using blue/black ink fountain pen only.</li><li>Be strictly careful with Time Limits. Once the candle burns out, papers will be snatched!</li></ul><div className="mt-2.5 text-right font-handwritten text-[13px] text-amber-900/70 italic font-semibold">— Prof. Alan Shaw (CS Dean)</div></div></div><div className="text-center mt-6 text-[10px] font-mono uppercase tracking-widest text-orange-200/40 select-none pb-4">&copy; 1974 - 2026 COMPUTER SCIENCE DEPT. ALL RIGHTS RESERVED.</div></div>}
